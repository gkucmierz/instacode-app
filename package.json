{
  "name": "Instacode",
  "description": "Scratchpad for instant JavaScript code running",
  "version": "1.3.9",
  "author": "Grzegorz Kućmierz",
  "homepage": "https://github.com/gkucmierz/instacode-app",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.html dist/404.html && node -e \"require('fs').writeFileSync('dist/version.json', JSON.stringify({version: require('./package.json').version}))\"",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui --ui-port=34219",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report --port=34219"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.1.6",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@gkucmierz/utils": "^2.1.0",
    "@uiw/codemirror-themes-all": "^4.25.9",
    "codemirror": "^6.0.1",
    "copy-to-clipboard": "^3.3.3",
    "eventemitter3": "^4.0.7",
    "javascript-stringify": "^2.1.0",
    "lz-string": "^1.4.4",
    "meriyah": "^4.3.3",
    "nano-ui": "^1.0.1",
    "normalize.css": "^8.0.1",
    "primeicons": "^6.0.1",
    "primevue": "^3.18.0",
    "vue": "^3.2.41",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^8.22.0",
    "eslint-plugin-vue": "^9.3.0",
    "husky": "^8.0.2",
    "sass": "^1.56.1",
    "sass-loader": "^13.2.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  }
}
